# ---------------------------
# Runtime mode
# ---------------------------
ENV=development

# ---------------------------
# Backend API
# ---------------------------
BACKEND_PORT=8000
PORT=8000
JWT_SECRET=change_me_with_a_long_random_secret

# ---------------------------
# PostgreSQL
# ---------------------------
POSTGRES_DB=trombiflow
POSTGRES_USER=trombiflow
POSTGRES_PASSWORD=change_me_db_password
POSTGRES_PORT=5432
DATABASE_URL=postgresql://trombiflow:change_me_db_password@db:5432/trombiflow

# ---------------------------
# Frontend
# ---------------------------
FRONTEND_PORT=5173
VITE_API_BASE_URL=http://localhost:8000/api

# ---------------------------
# Storage
# ---------------------------
STORAGE_TYPE=local
UPLOAD_DIR=/data/uploads

# ---------------------------
# S3 / MinIO (used when STORAGE=s3)
# ---------------------------
S3_BUCKET=trombiflow
S3_ENDPOINT=http://minio:9000
S3_KEY=minioadmin
S3_SECRET=minioadmin
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ---------------------------
# Deployment (docker-compose.prod.yml)
# ---------------------------
# Example: babakam870/trombiflow
GITHUB_REPOSITORY_LOWER=babakam870/trombiflow
# Injected by CI in production deploys.
IMAGE_TAG=latest
