# Base de données
DATABASE_URL=postgresql://trombiflow:your_postgres_password@db:5432/trombiflow
POSTGRES_DB=trombiflow
POSTGRES_USER=trombiflow
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_PORT=5432

# Backend
ENV=development
PORT=8000
BACKEND_PORT=8000
JWT_SECRET=your_jwt_secret_min_32_characters

# Frontend
FRONTEND_PORT=5173
VITE_API_BASE_URL=http://localhost:8000/api

# Stockage S3 (Supabase Storage)
STORAGE_TYPE=s3
UPLOAD_DIR=/data/uploads
S3_BUCKET=trombiflow
S3_ENDPOINT=https://your_project_ref.supabase.co/storage/v1/s3
S3_REGION=eu-west-1
S3_KEY=your_s3_access_key
S3_SECRET=your_s3_secret_key

# Déploiement
GITHUB_REPOSITORY_LOWER=your_github_org/trombiflow
IMAGE_TAG=latest
