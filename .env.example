# ============================================================
# Configuration TrombiFlow - Fichier d'exemple (.env.example)
# ============================================================
# 
# Pour démarrer l'application en développement :
# 1. Copier ce fichier en .env : cp .env.example .env
# 2. Adapter les valeurs selon votre environnement
# 3. Lancer docker-compose : docker-compose up -d
#
# IMPORTANT : Ne JAMAIS commiter le fichier .env avec des secrets réels
#
# ============================================================
# Mode d'exécution
# ============================================================
ENV=development

# ============================================================
# Base de données PostgreSQL
# ============================================================
# Nom de la base de données
POSTGRES_DB=trombiflow

# Utilisateur PostgreSQL
POSTGRES_USER=trombiflow

# Mot de passe PostgreSQL (générer un mot de passe fort)
# EN DEV : vous pouvez utiliser une valeur simple pour tester
# EN PROD : générer avec : openssl rand -base64 32
POSTGRES_PASSWORD=change_me_with_a_strong_password

# Port PostgreSQL exposé localement
POSTGRES_PORT=5432

# URL complète de connexion à la base de données
# Format : postgresql://utilisateur:mot_de_passe@host:port/database
DATABASE_URL=postgresql://trombiflow:change_me_with_a_strong_password@db:5432/trombiflow

# ============================================================
# Backend (API FastAPI)
# ============================================================
# Port du serveur backend
BACKEND_PORT=8000
PORT=8000

# Secret JWT pour la signature des tokens
# EN PROD : générer une clé robuste : openssl rand -base64 32
JWT_SECRET=change_me_with_a_long_random_secret_min_32_characters

# ============================================================
# MinIO (Stockage S3-compatible)
# ============================================================
# Image MinIO (tag ou digest SHA256)
MINIO_IMAGE=minio/minio:latest

# Utilisateur root MinIO
MINIO_ROOT_USER=change_me_minioadmin

# Mot de passe root MinIO
# EN DEV : vous pouvez utiliser une valeur simple
# EN PROD : générer avec : openssl rand -base64 32
MINIO_ROOT_PASSWORD=change_me_with_a_strong_minio_password

# Ports MinIO
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ============================================================
# Frontend (Application Web Vite/React)
# ============================================================
# Port du serveur frontend
FRONTEND_PORT=5173

# URL de base de l'API (utilisée par le frontend)
VITE_API_BASE_URL=http://localhost:8000/api

# ============================================================
# Stockage
# ============================================================
# Type de stockage pour les uploads : local ou s3
# - local : stockage sur disque local (/data/uploads)
# - s3 : stockage sur MinIO/S3 (utilise S3_* variables ci-dessous)
STORAGE_TYPE=local

# Répertoire local pour les uploads
UPLOAD_DIR=/data/uploads

# ============================================================
# S3 / MinIO (utilisé si STORAGE_TYPE=s3)
# ============================================================
# Bucket S3/MinIO
S3_BUCKET=trombiflow

# Endpoint S3/MinIO
S3_ENDPOINT=http://minio:9000

# Clés d'accès S3/MinIO
S3_KEY=change_me_minioadmin
S3_SECRET=change_me_with_a_strong_minio_password

# ============================================================
# Déploiement (docker-compose.prod.yml uniquement)
# ============================================================
# Format : owner/repository (en minuscules)
# Exemple : babakam870/trombiflow
GITHUB_REPOSITORY_LOWER=your_github_org/trombiflow

# Tag de l'image (injecté par CI avec le SHA du commit)
# En local : vous pouvez utiliser 'latest' ou 'dev'
IMAGE_TAG=latest

# ============================================================
# Production - Variables optionnelles supplémentaires
# ============================================================
# À décommenter et configurer selon vos besoins

# Sentry (monitoring d'erreurs)
# SENTRY_DSN=https://xxxxx@sentry.io/xxxxx

# Niveau de log
# LOG_LEVEL=info

# CORS - Domaines autorisés (JSON array)
# CORS_ORIGINS=["https://votre-domaine.com"]

# Base URL publique de l'application
# ALLOWED_HOSTS=["votre-domaine.com"]
