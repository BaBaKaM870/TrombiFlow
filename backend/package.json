{
  "name": "trombiflow-backend",
  "version": "1.0.0",
  "description": "Backend API for TrombiFlow — gestion et génération de trombinoscopes scolaires",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "test": "jest --testEnvironment=node --forceExit",
    "test:coverage": "jest --testEnvironment=node --coverage --forceExit"
  },
  "dependencies": {
    "bcryptjs": "2.4.3",
    "cors": "2.8.5",
    "csv-parse": "5.5.6",
    "dotenv": "16.4.5",
    "express": "4.19.2",
    "jsonwebtoken": "9.0.2",
    "multer": "1.4.5-lts.1",
    "pdfkit": "0.15.0",
    "pg": "8.11.5",
    "sharp": "0.33.3"
  },
  "devDependencies": {
    "jest": "29.7.0",
    "nodemon": "3.1.0",
    "supertest": "7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ]
  }
}
