# ── Base de données PostgreSQL ──────────────────────────
# Utiliser ce fichier uniquement pour lancer le backend SANS Docker (uvicorn en local).
# Pour Docker Compose, copier le .env.example à la racine du projet.
DATABASE_URL=postgresql://trombiflow:your_postgres_password@localhost:5432/trombiflow

# ── Authentification JWT ─────────────────────────────────
JWT_SECRET=change_me_in_production

# ── Stockage des fichiers uploadés ──────────────────────
UPLOAD_DIR=uploads
STORAGE_TYPE=local

# ── URL publique du serveur (utilisée dans le HTML généré)
BASE_URL=http://localhost:8000
