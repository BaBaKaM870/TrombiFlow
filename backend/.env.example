NODE_ENV=development
PORT=3000

# PostgreSQL
DATABASE_URL=postgresql://trombiflow:trombiflow_dev_password@localhost:5432/trombiflow

# JWT
JWT_SECRET=change_me_with_a_long_random_secret

# Storage : local | s3
STORAGE=local
UPLOAD_DIR=./uploads

# S3 / MinIO (uniquement si STORAGE=s3)
S3_BUCKET=trombiflow
S3_ENDPOINT=http://localhost:9000
S3_KEY=minioadmin
S3_SECRET=minioadmin

# URL publique du backend (pour les liens photos dans les exports HTML)
BASE_URL=http://localhost:3000
